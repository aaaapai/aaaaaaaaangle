target_os = "android"
target_cpu = "x86"
is_component_build = false
is_debug = false
angle_build_all = false
angle_expose_non_conformant_extensions_and_versions = true
jobs = 6
enable_iterator_debugging = false
symbol_level = 0
use_goma = false
dcheck_always_on = false
angle_assert_always_on = false
is_clang = true
android_ndk_api_level = 26
strip_debug_info = true
generate_debug_info = false
enable_resource_allowlist_generation = false
angle_enable_vulkan = true
angle_enable_vulkan_validation_layers = false
angle_enable_gl = true
angle_enable_d3d9 = false
angle_enable_d3d11 = false
angle_enable_null = false
angle_enable_wgpu = false
angle_enable_swiftshader = false
angle_enable_metal = false
angle_enable_essl = true
angle_enable_glsl = true

angle_expose_non_conformant_extensions_and_versions = true
build_angle_deqp_tests = false
angle_enable_vulkan_shared_ring_buffer_cmd_alloc = true
angle_enable_vulkan_validation_layers = false
angle_enable_trace = false

use_lto = true

angle_build_tests = false

cflags_c = [
  "-Wno-unused-variable",
  "-Wno-error=unused-variable",
  "-Wno-error",
  "-O3",
  "-mllvm",
  "-polly",
  "-fno-semantic-interposition",
  "-mllvm",
  "-hot-cold-split=true",
  "-fdata-sections",
  "-ffunction-sections",
  "-fmerge-all-constants",
  "-ftree-vectorize",
  "-fvectorize",
  "-fslp-vectorize",
  "-pipe",
  "-integrated-as",
  "-mllvm",
  "-polly-vectorizer=stripmine",
  "-mllvm",
  "-polly-invariant-load-hoisting",
  "-mllvm",
  "-polly-run-inliner",
  "-mllvm",
  "-polly-run-dce",
  "-mllvm",
  "-polly-detect-keep-going",
  "-mllvm",
  "-polly-ast-use-context",
  "-mllvm",
  "-polly-parallel",
  "-flto",
  "-D_FILE_OFFSET_BITS=64",
  "-D__USE_BSD",
  "-D_ALLBSD_SOURCE",
  "-mllvm",
  "-inlinehint-threshold=100000"
]

cflags_cc = [
  "-Wno-unused-variable",
  "-Wno-error=unused-variable",
  "-Wno-error",
  "-O3",
  "-mllvm",
  "-polly",
  "-fno-semantic-interposition",
  "-mllvm",
  "-hot-cold-split=true",
  "-fdata-sections",
  "-ffunction-sections",
  "-fmerge-all-constants",
  "-ftree-vectorize",
  "-fvectorize",
  "-fslp-vectorize",
  "-pipe",
  "-integrated-as",
  "-mllvm",
  "-polly-vectorizer=stripmine",
  "-mllvm",
  "-polly-invariant-load-hoisting",
  "-mllvm",
  "-polly-run-inliner",
  "-mllvm",
  "-polly-run-dce",
  "-mllvm",
  "-polly-detect-keep-going",
  "-mllvm",
  "-polly-ast-use-context",
  "-mllvm",
  "-polly-parallel",
  "-flto",
  "-D_FILE_OFFSET_BITS=64",
  "-D__USE_BSD",
  "-D_ALLBSD_SOURCE",
  "-mllvm",
  "-inlinehint-threshold=100000"
]

ldflags = [
  "-fuse-ld=lld",
  "-Wl,--gc-sections",
  "-flto",
  "-Wl,--lto-O3",
  "-Wl,-O3",
  "-Wl,--as-needed",
  "-Wl,--exclude-libs,ALL"
]

treat_warnings_as_errors = false
libcxx_abi_unstable = true
android_ndk_path = "/usr/local/lib/android/sdk/ndk/27.3.13750724"
android_ndk_version = "r27d"

# Whether the ANGLE translator should be built with IR instead
# THIS IS CURRENTLY EXPERIMENTAL.
angle_ir = true

angle_enable_perf_counter_output = false

angle_standalone = true

angle_has_frame_capture = false

enable_stripping = true

use_cxx23 = true

c_wrapper="ccache"
cc_wrapper="ccache"

enable_unused_resource_stripping = true
exclude_unwind_tables = true
use_clang_coverage = false
angle_force_context_check_every_call = true
use_lld = true

angle_use_android_tls_slot = true

use_custom_libcxx_for_host = false
optimize_for_fuzzing = false
use_custom_libcxx = true
use_rtti = false
use_dummy_lastchange = false


rust_lto = "fat"

angle_has_frame_capture = false
